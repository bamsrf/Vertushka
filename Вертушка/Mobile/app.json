{
  "expo": {
    "name": "Вертушка",
    "slug": "vertushka",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vertushka",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vertushka.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Приложению нужен доступ к камере для сканирования штрихкодов пластинок"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.vertushka.app",
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Приложению нужен доступ к камере для сканирования штрихкодов пластинок"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "privacyPolicyUrl": "https://vinyl-vertushka.ru/privacy",
      "termsOfServiceUrl": "https://vinyl-vertushka.ru/terms",
      "devApiUrl": "https://api.vinyl-vertushka.ru/api",
      "sentryDsn": "",
      "router": {},
      "eas": {
        "projectId": "a603ba4b-61d4-4179-9384-e5f3ed4e4bca"
      }
    },
    "owner": "bamsrf",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a603ba4b-61d4-4179-9384-e5f3ed4e4bca"
    }
  }
}
